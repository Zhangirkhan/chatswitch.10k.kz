# Скопируйте в /var/www/accel/deploy/config.env и отредактируйте.
# cp deploy/cluster/config.env.example /var/www/accel/deploy/config.env

# Корень release-деплоя (shared + releases)
ACCEL_BASE=/var/www/accel

# Симлинк, на который смотрят nginx / supervisor / sudoers (не менять без правки конфигов)
APP_LINK=/var/www/accel.kz

# Ветка для git pull при деплое
GIT_BRANCH=main

# Сколько релизов хранить на диске
KEEP_RELEASES=5

# Перезапускать Node WhatsApp-сервис после деплоя (1 = да, сессии могут переподключиться)
RESTART_WHATSAPP=0

# PHP-FPM pool для Accel (после install-pool.sh)
PHP_FPM_SERVICE=php8.3-fpm

# Supervisor program names (через пробел)
SUPERVISOR_PROGRAMS="accel-queue-default:* accel-reverb"
