# Accel — почасовой бэкап MySQL (chatswitch), хранение 5 часов
SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/sbin:/bin:/usr/sbin:/usr/bin

# Каждый час в :00 (время сервера, APP_TIMEZONE=Asia/Almaty)
0 * * * * root /var/www/accel.kz/deploy/scripts/backup-mysql.sh >> /var/www/accel/shared/storage/logs/mysql-backup.log 2>&1
