APP_NAME=Accel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=https://accel.kz

# Multi-tenancy (subdomains)
TENANCY_ROOT_DOMAIN=accel.kz
TENANCY_ADMIN_SUBDOMAIN=app
TENANCY_FALLBACK_SLUG=demo
SUPER_ADMIN_EMAIL=super@accel.kz

# Google reCAPTCHA (вход и восстановление пароля на {tenant}.accel.kz и app.accel.kz)
RECAPTCHA_ENABLED=false
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_VERSION=v3
RECAPTCHA_MIN_SCORE=0.5

# Swagger / OpenAPI на {tenant}.accel.kz/docs/api (HTTP Basic Auth)
DOCS_API_USERNAME=docs
DOCS_API_PASSWORD=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
# SESSION_SAME_SITE=lax
SESSION_PATH=/
SESSION_DOMAIN=null

# Mobile API (Laravel Sanctum). Положительное число — срок жизни токена в минутах (например 10080 = 7 суток).
# Пусто — токены не истекают по времени (как раньше).
SANCTUM_EXPIRATION_MINUTES=43200
CORS_ALLOWED_ORIGINS="${APP_URL}"
REVERB_ALLOWED_ORIGINS="${APP_URL}"
WHATSAPP_SERVICE_ALLOWED_IPS=127.0.0.1,::1

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Почта (свой SMTP на mail.accel.kz) ---
MAIL_MAILER=smtp
MAIL_HOST=mail.accel.kz
MAIL_PORT=587
MAIL_USERNAME=notify@accel.kz
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=notify@accel.kz
MAIL_FROM_NAME="${APP_NAME}"
#
# Dev без SMTP (письма в storage/logs/laravel.log):
# MAIL_MAILER=log
MAIL_SCHEME=null

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

WHATSAPP_SERVICE_URL=http://127.0.0.1:3050
WHATSAPP_SERVICE_TOKEN=
WHATSAPP_WEBHOOK_SECRET=

# Ёмкость WhatsApp (лимит = RAM сервера, не тариф): (SERVER − RESERVED) / SESSION
WHATSAPP_SERVER_RAM_MB=16384
WHATSAPP_RESERVED_RAM_MB=7168
WHATSAPP_SESSION_RAM_MB=450
# WHATSAPP_MAX_SESSIONS_GLOBAL=
# WHATSAPP_MAX_SESSIONS_PER_TENANT=

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=6001
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# OpenAI — нужен для правой панели «AI-ассистент оператора» в окне диалога.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
# null = auto (gpt-5*, gpt-4.1*, o* → max_completion_tokens); true/false to override
# OPENAI_USE_MAX_COMPLETION_TOKENS=
# Демо-тенант: доп. лимиты токенов (модель та же — OPENAI_MODEL).
OPENAI_DEMO_MAX_TOKENS_MULTIPLIER=2
OPENAI_DEMO_MAX_TOKENS_CAP=4096
OPENAI_DEMO_TIMEOUT=90
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT=90
OPENAI_TRANSCRIBE_TIMEOUT=180
OPENAI_WHISPER_MODEL=whisper-1
# Принудительный язык Whisper (ISO-639-1). Обычно оставляем пустым: ru/kk определяются автоматически.
# OPENAI_WHISPER_LANGUAGE=kk
ACCEL_WHISPER_DEFAULT_LANGUAGE=auto
ACCEL_WHISPER_AUTO_DETECT_LANGUAGE=true
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
ACCEL_TRANSCRIBE_AUDIO=true
ACCEL_AI_VOICE_REPLIES=true
# Минуты простоя в чате перед автоответом AI (0 = сразу; для автономного AI-оркестратора держите 0)
ACCEL_AI_IDLE_REPLY_MINUTES=0
ACCEL_TRANSCRIBE_MIN_DURATION_SECONDS=1
ACCEL_TRANSCRIBE_MAX_DURATION_SECONDS=600

# RAG по базе знаний (embeddings + top-k retrieval в промпт AI)
KNOWLEDGE_RAG_ENABLED=true
KNOWLEDGE_RAG_TOP_K=12
KNOWLEDGE_RAG_MIN_SIMILARITY=0.30
KNOWLEDGE_RAG_MAX_RULES=5

# Kazakhstan locale assistant (RU/KK mixed, few-shot, slang RAG)
LOCALE_ASSISTANT_ENABLED=true
LOCALE_FEW_SHOT_ENABLED=true
LOCALE_FEW_SHOT_COUNT=5
LOCALE_RAG_ENABLED=false
LOCALE_RAG_TOP_K=6
LOCALE_RAG_MIN_SIMILARITY=0.28
LOCALE_RAG_SLANG_THRESHOLD=0.35

# Задачи по отделам во вкладке «Организация» (отдельно от внутреннего чата отделов)
ORGANIZATION_DEPARTMENT_TASKS=true
