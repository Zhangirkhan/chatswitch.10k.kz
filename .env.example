APP_NAME=Accel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=https://accel.kz

# Multi-tenancy (subdomains)
TENANCY_ROOT_DOMAIN=accel.kz
TENANCY_ADMIN_SUBDOMAIN=app
TENANCY_FALLBACK_SLUG=demo
SUPER_ADMIN_EMAIL=super@accel.kz

# Google reCAPTCHA (вход и восстановление пароля на {tenant}.accel.kz и app.accel.kz)
RECAPTCHA_ENABLED=false
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_VERSION=v3
RECAPTCHA_MIN_SCORE=0.5

# Swagger / OpenAPI на {tenant}.accel.kz/docs/api (HTTP Basic Auth)
DOCS_API_USERNAME=docs
DOCS_API_PASSWORD=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
# SESSION_SAME_SITE=lax
SESSION_PATH=/
SESSION_DOMAIN=null

# Mobile API (Laravel Sanctum). Положительное число — срок жизни токена в минутах (например 10080 = 7 суток).
# Пусто — токены не истекают по времени (как раньше).
SANCTUM_EXPIRATION_MINUTES=43200
CORS_ALLOWED_ORIGINS="${APP_URL}"
REVERB_ALLOWED_ORIGINS="${APP_URL}"
WHATSAPP_SERVICE_ALLOWED_IPS=127.0.0.1,::1

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Почта (свой SMTP на mail.accel.kz) ---
MAIL_MAILER=smtp
MAIL_HOST=mail.accel.kz
MAIL_PORT=587
MAIL_USERNAME=notify@accel.kz
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=notify@accel.kz
MAIL_FROM_NAME="${APP_NAME}"
#
# Dev без SMTP (письма в storage/logs/laravel.log):
# MAIL_MAILER=log
MAIL_SCHEME=null

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

WHATSAPP_SERVICE_URL=http://127.0.0.1:3050
WHATSAPP_SERVICE_TOKEN=
WHATSAPP_WEBHOOK_SECRET=

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=6001
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# OpenAI — нужен для правой панели «AI-ассистент оператора» в окне диалога.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT=45
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# RAG по базе знаний (embeddings + top-k retrieval в промпт AI)
KNOWLEDGE_RAG_ENABLED=true
KNOWLEDGE_RAG_TOP_K=12
KNOWLEDGE_RAG_MIN_SIMILARITY=0.30
KNOWLEDGE_RAG_MAX_RULES=5
